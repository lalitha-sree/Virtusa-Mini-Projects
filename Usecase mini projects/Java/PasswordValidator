import java.util.Scanner;
import java.util.ArrayList;
import java.util.List;

public class PasswordValidator {

    static List<String> validate(String password) {
        List<String> failures = new ArrayList<>();

        //Policy 1: Minimum length
        if (password.length() < 8) {
            failures.add("Too short, the password should have a minimum of 8 characters, yours has " + password.length() + ")");
        }

        // Policies 2 & 3: Character composition
        boolean hasUppercase = false;
        boolean hasDigit     = false;

        for (int i = 0; i < password.length(); i++) {
            char ch = password.charAt(i);

            if (Character.isUpperCase(ch)) {
                hasUppercase = true;
            }
            if (Character.isDigit(ch)) {
                hasDigit = true;
            }

        }

        if (!hasUppercase) {
            failures.add("Missing an uppercase letter");
        }
        if (!hasDigit) {
            failures.add("Missing a digit");
        }

        return failures;
    }


    static void printFeedback(List<String> failures) {
        System.out.println("\nPassword rejected for the following reasons:");
        for (String reason : failures) {
            System.out.println(reason);
        }
        System.out.println();
    }
    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        System.out.println("SafeLog : Employee Portal");
        System.out.println("Password should contain 8+ characters, atleast 1 uppercase and 1 digit");

        String password;

        while (true) {
            System.out.print("Enter password: ");
            password = scanner.nextLine();
            List<String> failures = validate(password);

            if (failures.isEmpty()) {
                System.out.println("\nPassword accepted! ");
                break;  
            } else {
                printFeedback(failures);
            }
        }

        scanner.close();
    }
}
